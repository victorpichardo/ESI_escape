}

void guardar_jugador_en_fichero(const char *nombre_fichero, Jugador j) {
    FILE *f;

    f = fopen(nombre_fichero, "a");
    if (f == NULL) {
        printf("Error al abrir el fichero.\n");
        return;
    }

    fprintf(f, "%s-%s-%s-%s\n",
            j.id_jugador, j.nombre, j.usuario, j.contrasena);

    fclose(f);
}
