int registrar_jugador(Jugador jugadores[], int *num_jugadores,const char *nombre, const char *usuario, const char *contrasena) {
    char nuevo_id[MAX_ID];

    if (*num_jugadores >= MAX_JUGADORES) {
        return 0;   // sin espacio
    }

    if (existe_usuario(jugadores, *num_jugadores, usuario)) {
        return -1;  // usuario ya existe
    }

    generar_id_jugador(jugadores, *num_jugadores, nuevo_id);

    strcpy(jugadores[*num_jugadores].id_jugador, nuevo_id);
    strcpy(jugadores[*num_jugadores].nombre, nombre);
    strcpy(jugadores[*num_jugadores].usuario, usuario);
